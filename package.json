{
  "name": "dvanguard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "sh -c 'if [ \"$SKIP_DB_PUSH_ON_DEV\" = \"1\" ]; then echo \"[db] skipping db push on dev\"; else npm run db:push; fi'",
    "dev": "next dev",
    "dev:no-db": "next dev",
    "build": "next build",
    "start": "next start",
    "worker:dev": "node worker/server.mjs",
    "stripe:listen": "node scripts/stripe-listen.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:init": "supabase init",
    "db:link": "supabase link --project-ref \"$SUPABASE_PROJECT_REF\" --password \"$SUPABASE_DB_PASSWORD\"",
    "db:list": "supabase migration list --linked",
    "db:dry": "supabase db push --linked --dry-run",
    "db:push": "supabase db push --linked --yes"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.56.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^21.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "typescript": "^5.8.2"
  }
}
